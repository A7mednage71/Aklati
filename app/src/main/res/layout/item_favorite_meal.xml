<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivFavMealImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/aklati_logo"
                tools:src="@tools:sample/backgrounds/scenic" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFavMealName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/poppins_bold"
                android:lineSpacingExtra="2dp"
                android:maxLines="1"
                android:textColor="#212121"
                android:textSize="18sp"
                tools:text="Spicy Chicken Pasta" />

            <com.google.android.material.chip.Chip
                android:id="@+id/tvFavMealCategory"
                style="@style/Widget.Material3.Chip.Assist.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="6dp"
                android:clickable="false"
                android:focusable="false"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#FF5722"
                android:textSize="12sp"
                app:chipBackgroundColor="#FFF3E0"
                app:chipCornerRadius="12dp"
                app:chipStrokeWidth="0dp"
                tools:text="Chicken" />

            <TextView
                android:id="@+id/tvFavMealArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:drawablePadding="6dp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center_vertical"
                android:textColor="#616161"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_location"
                app:drawableTint="#616161"
                tools:text="Italian Cuisine" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveFavorite"
            style="@style/Widget.Material3.Button.Icon"
            android:layout_width="40dp"
            android:layout_height="46dp"
            android:padding="0dp"
            android:text=""
            app:backgroundTint="#FFF3E0"
            app:icon="@drawable/ic_favorite_filled"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:iconTint="#FF5722"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:strokeColor="#FF5722"
            app:strokeWidth="1dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>