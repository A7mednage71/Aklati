<resources>

    <style name="Base.Theme.Aklati" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/app_font</item>
        <item name="fontFamily">@font/app_font</item>
    </style>

    <style name="Theme.Aklati" parent="Base.Theme.Aklati" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/aklati_logo_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Aklati</item>
    </style>

    <style name="BottomNavTextActive">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavTextInactive">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">11sp</item>
    </style>

</resources>